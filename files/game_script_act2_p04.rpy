# game/game_script_act2.rpy:2296
translate spanish game_script_act2_87aa068a:

    # n zz3 e4a mh "I tried to, a few years ago."
    n zz3 e4a mh "Hace unos años lo intenté."

# game/game_script_act2.rpy:2297
