# game/game_script_act2.rpy:6133
translate spanish game_script_act2_48d88bf5:

    # s b1b e1b mb "Oh, well...{w}alright."
    s b1b e1b mb "Ah, pues... eh,{w} vale."

# game/game_script_act2.rpy:6143
